# Netlify environment variables
# Paste these into: Site settings → Environment variables
# Do NOT commit real secrets. Replace every REPLACE_ME / placeholder.

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://getscrubbed.netlify.app

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=REPLACE_ME
EMAIL_PASS=REPLACE_ME
EMAIL_FROM="Scrubbed" <REPLACE_ME>

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=REPLACE_ME
SUPABASE_ANON_KEY=REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
SUPABASE_JWT_SECRET=REPLACE_ME

# ── Stripe (LIVE mode for production) ────────────────────────────────────────
# Create live prices: turn OFF Test mode in Stripe, then run:
#   $env:STRIPE_SECRET_KEY="sk_live_..."
#   node stripe-setup.js
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
STRIPE_STARTER_PRICE_ID=price_REPLACE_ME
STRIPE_PRO_PRICE_ID=price_REPLACE_ME
STRIPE_PRO_ANNUAL_PRICE_ID=price_REPLACE_ME
STRIPE_CYCLE_PASS_PRICE_ID=price_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Optional — grandfather old $49 Cycle Pass subscribers
# STRIPE_CYCLE_PASS_LEGACY_PRICE_ID=price_REPLACE_ME

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_ME

# ── Optional ─────────────────────────────────────────────────────────────────
# EARLY_ACCESS_SECRET=

# ── Webhook (Stripe Dashboard → Developers → Webhooks → Live) ────────────────
# Endpoint URL: https://getscrubbed.netlify.app/stripe/webhook
# Events:
#   checkout.session.completed
#   customer.subscription.updated
#   customer.subscription.deleted
